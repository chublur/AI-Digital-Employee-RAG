# ==========================================
# 复制本文件为 .env，填入你自己的值
# cp .env.example .env
# ==========================================

# LLM 提供商选择: ollama（本地）或 deepseek（API）
LLM_PROVIDER=ollama

# --- Ollama 本地配置 ---
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=qwen2:7b

# --- DeepSeek API 配置（使用 deepseek 时必填）---
DEEPSEEK_API_KEY=your_deepseek_api_key_here
DEEPSEEK_MODEL=deepseek-chat

# --- 翻译配置 ---
# 是否对抓取到的非中文网页自动翻译（默认关闭，开启会增加 LLM 调用次数）
TRANSLATION_ENABLED=false

# --- LangSmith 链路追踪（可选，不填则关闭追踪）---
# 1. 注册: https://smith.langchain.com
# 2. 创建 API Key: Settings → API Keys → Create API Key
# 3. 填入下方，重启服务即生效
LANGCHAIN_TRACING_V2=false
LANGCHAIN_API_KEY=ls__your_key_here
LANGCHAIN_PROJECT=ai-digital-employee

# --- Qdrant 向量数据库（本地 Docker 默认值无需修改）---
# 本地开发：docker compose up -d 启动后保持默认
# 云端部署：填入 Qdrant Cloud 的地址
QDRANT_HOST=localhost
QDRANT_PORT=6333
QDRANT_COLLECTION=knowledge_base

# --- 系统安全配置 ---
API_KEY=your-secret-key-change-this

# --- RAG 参数（可选，有默认值）---
# CHUNK_SIZE=800
# RETRIEVAL_TOP_K=10
# RERANK_TOP_K=4

# --- MinerU PDF 兜底（扫描件/复杂版式，可选）---
# 安装：pip install "mineru[core]"
# MINERU_ENABLED=true
# MINERU_MIN_CHARS=100
# MINERU_BACKEND=pipeline
# MINERU_METHOD=auto
# MINERU_FORMULA=false
# MINERU_TABLE=true
# MINERU_LANGUAGE=ch
# MINERU_TIMEOUT=600
# 提速：先常驻 mineru-api，避免每次上传冷启动（可省 20~30 秒）
#   终端执行：mineru-api --host 127.0.0.1 --port 8789
# MINERU_API_URL=http://127.0.0.1:8789
# 仅解析部分页：MINERU_START_PAGE=0  MINERU_END_PAGE=9
